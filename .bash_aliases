alias rm='rm -v --interactive=always'
alias mkdir='mkdir -v'
alias chmod='chmod -v'
alias cp='cp -v'
alias cat='batcat'
alias free='free -h'

###################################################################
############################## lsd alias ##########################
###################################################################
alias ls='lsd'
alias la='ls -a'
alias ll='ls -l'
alias lla='ls -al'
alias lt='ls --tree'

###################################################################
############################## GIT ################################
###################################################################
alias config='/usr/bin/git --git-dir=$HOME/.cfg --work-tree=$HOME'
